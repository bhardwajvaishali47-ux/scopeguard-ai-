parameters	
jsCode	'const items = [];\n\nfor (const sprint of $input.all()) {\n  const sprintData = sprint.json;\n  \n  const requestBody = {\n    model: "claude-opus-4-5",\n    max_tokens: 1024,\n    system: "You are ScopeGuard, an expert Agile coach and scope creep detection engine for NovaTech Solutions. Analyse sprint data and return only raw JSON, no prose, no markdown, no code fences.",\n    messages: [\n      {\n        role: "user",\n        content: `Analyse this sprint data for scope creep. Flag any story where was_in_original_plan is false, or label is unplanned or critical, or story_points are high and added mid-sprint.\n\nSprint Data: ${JSON.stringify(sprintData)}\n\nReturn exactly this JSON structure:\n{\n  "risk_level": "LOW or MEDIUM or HIGH or CRITICAL",\n  "scope_creep_detected": true or false,\n  "changed_items": [\n    {\n      "story_id": "id here",\n      "title": "title here",\n      "reason": "why flagged",\n      "severity": "LOW or MEDIUM or HIGH"\n    }\n  ],\n  "recommended_action": "one clear action for the PM",\n  "summary": "two sentence summary"\n}`\n      }\n    ]\n  };\n\n  items.push({\n    json: {\n      sprint_id: sprintData.id,\n      team_id: sprintData.team_id,\n      claudeBody: JSON.stringify(requestBody)\n    }\n  });\n}\n\nreturn items;'
